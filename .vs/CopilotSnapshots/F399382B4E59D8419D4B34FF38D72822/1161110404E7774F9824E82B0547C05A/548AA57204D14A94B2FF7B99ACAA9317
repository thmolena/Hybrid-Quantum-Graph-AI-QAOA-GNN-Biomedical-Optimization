    "fig, ax = plt.subplots(figsize=(4,4))\n",
    "disp.plot(ax=ax)\n",
    "plt.title('Confusion matrix on test set')\n",
    "plt.show()\n",
    "\n",
    "print('\\nClassification report:\\n', classification_report(y[test_idx.numpy()], preds[test_idx.numpy()]))"
