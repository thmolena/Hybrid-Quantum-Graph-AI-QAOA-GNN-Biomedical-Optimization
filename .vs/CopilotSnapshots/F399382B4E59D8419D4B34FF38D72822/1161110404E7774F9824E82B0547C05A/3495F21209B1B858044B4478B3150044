    "# Cell 2: QAOA mini-demo (reuse earlier code)\n",
    "from scipy.optimize import minimize\n",
    "\n",
    "p=1\n",
    "n=6\n",
    "G = sample_erdos_renyi(n, p_edge=0.5, seed=7)\n",
    "edges = list(G.edges())\n",
    "\n",
    "# classical optimize\n",
    "def classical_optimize(n, edges, p):\n",
    "    def loss(x):\n",
    "        gammas = x[:p]\n",
    "        betas = x[p:]\n",
    "        state = qaoa_state(n, edges, gammas, betas)\n",
    "        return -expected_cut(n, edges, state)\n",
    "    x0 = np.random.uniform(0, np.pi, size=2*p)\n",
    "    res = minimize(loss, x0, method='Nelder-Mead', options={'maxiter':200})\n",
    "    sol = res.x\n",
    "    return sol[:p], sol[p:]\n",
    "\n",
    "opt_g, opt_b = classical_optimize(n, edges, p)\n",
    "state_opt = qaoa_state(n, edges, opt_g, opt_b)\n",
    "val_opt = expected_cut(n, edges, state_opt)\n",
    "\n",
    "# save graph + results\n",
    "pd.DataFrame(edges, columns=['u','v']).to_csv(os.path.join(proj_root,'outputs','maxcut_graph.csv'), index=False)\n",
    "pd.DataFrame({'opt_gamma':opt_g, 'opt_beta':opt_b}).to_csv(os.path.join(proj_root,'outputs','qaoa_classical_angles.csv'), index=False)\n",
    "print('QAOA classical expected cut:', val_opt)"
   ]
